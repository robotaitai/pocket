{
  "name": "@pocket/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite --config vite.renderer.config.ts\" \"tsc -p tsconfig.json --watch\"",
    "build": "tsc -p tsconfig.json && vite build --config vite.renderer.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "start": "electron ."
  },
  "dependencies": {
    "@pocket/core-model": "workspace:*",
    "@pocket/ui": "workspace:*",
    "@pocket/rules-engine": "workspace:*",
    "@pocket/connectors-israel": "workspace:*",
    "@pocket/insights": "workspace:*",
    "better-sqlite3": "^11.9.1",
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "typescript": "~5.5.4",
    "vite": "^6.2.4",
    "vitest": "^3.1.1"
  }
}
